    "audit:root-cause": "tsx scripts/export-audit/diagnostics/root-cause-analysis.ts",
    "audit:export": "tsx scripts/export-audit/collect-routes.ts && playwright test",
    "audit:export:ci": "npm run build && npm run audit:export"
  },
  "dependencies": {
    "@studio-freight/lenis": "^1.0.42",
    "clsx": "^2.1.1",
