<IfModule mod_rewrite.c>
RewriteEngine On
Options +FollowSymLinks

# -------------------------------------------------
# 0. FORCE NON-WWW
# -------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# -------------------------------------------------
# 1. STATIC FILES
# -------------------------------------------------
RewriteRule ^(sitemap\.xml|sitemap-react\.xml|robots\.txt|llms\.txt)$ - [L]

# -------------------------------------------------
# 2. CUSTOM REDIRECTS
# -------------------------------------------------
Redirect 301 /unique-gifts-that-stand-out/ /blog/unique-gifts-that-stand-out/

RewriteRule ^product-category/gift-sets(/.*)?$ /product-category/premium-gift-sets$1 [R=301,L]
RewriteRule ^product-category/premiums-and-tools(/.*)?$ /product-category/luxury-corporate-gifts-dubai$1 [R=301,L]
RewriteRule ^shop/eco-friendly/7846(/.*)?$ /shop/eco-friendly/gift-set-b$1 [R=301,L]
RewriteRule ^shop/technology-and-accessories/8657(/.*)?$ /shop/technology-and-accessories/bamboo-photo-frame-with-digital-clock-and-weather-station$1 [R=301,L]
RewriteRule ^cookies(/.*)?$ /cookie-policy$1 [R=301,L]
RewriteRule ^blogs(/.*)?$ /blog$1 [R=301,L]

RedirectMatch 301 ^/blog/my-account/(.*)$ /
RedirectMatch 301 ^/blog/product/(.*)$ /
RedirectMatch 301 ^/blog/product-category/(.*)$ /
RedirectMatch 301 ^/blog/product-tag/(.*)$ /
RedirectMatch 301 ^/blog/shop/(.*)$ /
RedirectMatch 301 ^/blog/cart/?$ /cart$1 [R=301,L]
RedirectMatch 301 ^/blog/checkout/?$ /

# -------------------------------------------------
# 2b. SHOP MULTI-CATEGORY REDIRECTS (auto-generated)
