# FORCE uploads to blog uploads
RewriteRule ^wp-content/uploads/(.*)$ /blog/wp-content/uploads/$1 [L]

# -------------------------------------------------
# 3. HANDLE WORDPRESS (/blog)
# -------------------------------------------------
RewriteCond %{REQUEST_URI} ^/blog
RewriteRule ^blog(/.*)?$ /blog/index.php [L]

# # -------------------------------------------------
# # 2d. PASS WP REST API & ADMIN TO WORDPRESS
# # -------------------------------------------------
# RewriteRule ^wp-json(/.*)?$ /blog/wp-json$1 [L,QSA]
# RewriteRule ^wp-admin(/.*)?$ /blog/wp-admin$1 [L,QSA]
# RewriteRule ^wp-login\.php$ /blog/wp-login.php [L,QSA]
# RewriteRule ^wp-cron\.php$ /blog/wp-cron.php [L,QSA]

# # -------------------------------------------------
# # 3. HANDLE WORDPRESS (/blog)
# # -------------------------------------------------
# RewriteRule ^blog(/.*)?$ - [L]

# -------------------------------------------------
# 4. NEXT STATIC ASSETS
# -------------------------------------------------
RewriteRule ^_next/ - [L]
RewriteRule ^assets/ - [L]
RewriteRule ^static/ - [L]

# -------------------------------------------------
# 5. SERVE EXISTING FILES / FOLDERS
# -------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# -------------------------------------------------
# 6. FORCE 404 FOR UNKNOWN ROUTES
# (THIS is the key fix for trailing slash)
# -------------------------------------------------
# RewriteCond %{REQUEST_URI} !^/blog
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^.*$ /404.html [L]

</IfModule>

ErrorDocument 404 /404.html